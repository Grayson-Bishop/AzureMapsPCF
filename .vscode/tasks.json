{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "func",
			"label": "func: host start",
			"command": "host start",
			"problemMatcher": "$func-node-watch",
			"isBackground": true,
			"dependsOn": "npm watch (functions)",
			"options": {
				"cwd": "${workspaceFolder}/z_devFiles\\AzureFunction4Auth"
			}
		},
		{
			"type": "shell",
			"label": "npm build (functions)",
			"command": "cmd /c \"npm run build\"",
			"dependsOn": "npm clean (functions)",
			"problemMatcher": "$tsc",
			"options": {
				"cwd": "${workspaceFolder}/z_devFiles\\AzureFunction4Auth"
			}
		},
		{
			"type": "shell",
			"label": "npm watch (functions)",
			"command": "cmd /c \"npm run watch\"",
			"dependsOn": "npm clean (functions)",
			"problemMatcher": "$tsc-watch",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"isBackground": true,
			"options": {
				"cwd": "${workspaceFolder}/z_devFiles\\AzureFunction4Auth"
			}
		},
		{
			"type": "shell",
			"label": "npm install (functions)",
			"command": "cmd /c \"npm install\"",
			"options": {
				"cwd": "${workspaceFolder}/z_devFiles\\AzureFunction4Auth"
			}
		},
		{
			"type": "shell",
			"label": "npm prune (functions)",
			"command": "cmd /c \"npm prune --production\"",
			"dependsOn": "npm build (functions)",
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/z_devFiles\\AzureFunction4Auth"
			}
		},
		{
			"type": "shell",
			"label": "npm clean (functions)",
			"command": "cmd /c \"npm run clean\"",
			"dependsOn": "npm install (functions)",
			"options": {
				"cwd": "${workspaceFolder}/z_devFiles\\AzureFunction4Auth"
			}
		}
	]
}